  "keyFeatures": [
    "SQL Copilot with schema-aware AI assistance (Ask, Action, Context modes)",
    "Schema-aware autocomplete for tables, columns, functions, and aliases",
    "Intelligent multi-tab SQL editor with saved queries and result sets",
    "Built-in database chatbot for conversational data exploration",
    "Instant query visualization with charts",
    "ClickHouse deep integration with real-time monitoring (P50/P95 latency, QPM)",
    "ClickHouse privilege management UI for users, roles, and grants",
    "Pluggable AI provider architecture (OpenAI, Anthropic, Google, xAI, Qwen)",
    "Desktop app (macOS, Windows) and Docker self-hosted web deployment",
    "Organization and team management with billing support"
  ],
  "publicApiSurface": [
    "GET/POST /api/query — Execute SQL queries against a connection",
    "GET/POST /api/connection — Manage database connections",
    "POST /api/copilot — SQL Copilot AI actions (ask, fix, explain)",
    "POST /api/chat — Database chatbot conversation endpoint",
    "GET /api/monitoring — ClickHouse monitoring metrics",
    "GET/POST /api/privileges — ClickHouse user and role management",
    "POST /api/ai — AI provider gateway",
    "GET/POST /api/workspace — Workspace and saved queries management",
    "GET/POST /api/organization — Organization management",
    "POST /api/auth — Authentication (sign-in, sign-up, OAuth)"
  ]
}
